local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/Dede7zinho777/ui-lib/refs/heads/main/ui-library.lua"))()

local Window = OrionLib:MakeWindow({
    Name = "Minha Janela",
    HidePremium = false,
    SaveConfig = false,
    IntroEnabled = true
})

local Tab = Window:MakeTab({
    Name = "Teste",
    Icon = "rbxassetid://6031280882"
})

Tab:AddToggle({
    Name = "teste-msg",
    Default = false,
    Callback = function(Value)
        if Value then
            print("ATIVADO")
            OrionLib:MakeNotification({
                Name = "Teste",
                Content = "Ativado!",
                Time = 3
            })
        else
            print("DESATIVADO")
        end
    end
})

OrionLib:Init()
